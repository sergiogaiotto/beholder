# Beholder — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
.python-version

# Tests / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
.cache/

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Worktree do Claude Code
.claude/

# Secrets / config local
.env
.env.local
.env.production
.env.*.local

# Dados locais (volume montado em runtime)
data/
backups/

# Dados brutos do projeto (XLSX SAP, PDFs contratos, MSRV5 LPU, Analitico WF)
# Local canonico: C:\_PERSONAL\beholder_data\ (acessado via BEHOLDER_DATA_DIR)
# Defesa em profundidade: ignorar tambem qualquer FILES/ dentro do repo
FILES/
beholder_data/

# Outputs de probes/spikes — contem amostras de dados reais (CNPJs, contratos, precos)
# DATA_INVENTORY.json fica versionado (so hashes/metadata, sem dados de negocio)
docs/probe_*.json
docs/spike_*.json

# Caddy persistente (TLS certs/state) — fica no volume Docker, não no repo
caddy_data/
caddy_config/

# Logs
*.log
logs/

# Build artefacts
build/
dist/
*.whl
