# Beholder — Variáveis de ambiente
# Copie para .env e preencha com seus valores reais

# ===== Aplicação =====
APP_NAME=Beholder
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=troque-este-segredo-imediatamente-em-producao
APP_BASE_URL=http://localhost:8000

# ===== Banco — PostgreSQL via asyncpg =====
# Para rodar local com docker-compose, este DSN funciona out-of-the-box.
# Em produção, ajuste host/credenciais e (idealmente) habilite TLS.
DATABASE_URL=postgresql://beholder:beholder@localhost:5432/beholder

# Pool de conexões — calibrar conforme `max_connections` do PG e número
# de workers uvicorn (regra de bolso: pool_max * workers <= 80% do max).
PG_POOL_MIN_SIZE=5
PG_POOL_MAX_SIZE=20
PG_POOL_MAX_INACTIVE_CONNECTION_LIFETIME=300.0
PG_COMMAND_TIMEOUT=30.0
PG_STATEMENT_CACHE_SIZE=1024

# Para testes (pytest), usa um servidor PG separado com banco `beholder_test`:
# TEST_DATABASE_URL=postgresql://beholder:beholder@localhost:5432/beholder_test

# ===== Auth =====
# Bootstrap do primeiro usuário: NÃO há credenciais default. Quando a tabela
# users está vazia, a primeira submissão em /login (com QUALQUER username/senha
# que você escolher) cria o usuário ROOT. Trate-as como senha primária e guarde.
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# ===== LLMs — ClaroHub (on-prem) + Maritaca (cloud) =====
# Sem chave preenchida, o adaptador entra em modo mock (útil para dev offline).
# ClaroHub é OpenAI-compatible; é usado pelo módulo de Exploração SQL
# (Deep Agent / text2sql) e pode ser usado pela extração PDF/LLM em geral.
CLARO_HUB_API_KEY=
CLARO_HUB_ENDPOINT=https://hub-gpus.claro.com.br/gpt20
CLARO_HUB_MODEL=openai/gpt-oss-20b

MARITACA_API_KEY=
MARITACA_MODEL=sabia-4
MARITACA_BASE_URL=https://chat.maritaca.ai/api

# Proxy corporativo (obrigatório para alcançar o ClaroHub a partir de redes
# Claro). Sem o proxy preenchido, a chamada falha com timeout.
HTTP_PROXY=
HTTPS_PROXY=

# ===== Roteador de modelos (política padrão) =====
ROUTER_DEFAULT_MODEL=sabia-4
ROUTER_FALLBACK_MODEL=openai/gpt-oss-20b
ROUTER_CHEAP_MODEL=openai/gpt-oss-20b

# ===== Observabilidade =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

MLFLOW_TRACKING_URI=

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=beholder

# ===== Política (OPA) =====
OPA_URL=                       # vazio desativa o adaptador OPA

# ===== Guardrails =====
GUARDRAIL_INPUT_MAX_CHARS=20000
GUARDRAIL_INJECTION_BLOCK=true
GUARDRAIL_PII_REDACT=true
